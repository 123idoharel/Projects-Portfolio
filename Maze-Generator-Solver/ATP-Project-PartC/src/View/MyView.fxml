<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import View.MazeRepresentor?>


<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.MyViewController">

    <bottom>
        <HBox alignment="CENTER_LEFT" minHeight="80" prefHeight="510.0" prefWidth="843.0" spacing="10">
         <VBox prefHeight="510.0" prefWidth="122.0">
            <children>
               <Label prefHeight="18.0" prefWidth="120.0" text="Insert Rows" />
                <TextField fx:id="rowsText" />
               <Label prefHeight="18.0" prefWidth="120.0" text="Insert Cols" />
                <TextField fx:id="colsText" />
               <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="120.0" text="Generate Maze" onAction="#clicked_generate_maze"/>
               <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="124.0" text="Show Solution" onAction="#clicked_solve"/>
            </children>
         </VBox>
            <Label fx:id="goalStatusLabel"
                   text=""
                   style="-fx-text-fill: blue; -fx-font-size: 18px; -fx-font-weight: bold;"
                   visible="false" />
        </HBox>
    </bottom>

    <center>
        <StackPane fx:id="mazeStackPane" minWidth="400" minHeight="400">
            <MazeRepresentor fx:id="mr"
            onKeyPressed = "#handle_key_press"
            onMouseReleased="#handle_mouse_release"
            onMousePressed="#handle_mouse_pressed"
            onScroll="#handle_scroll"
            onMouseDragged="#handle_mouse_dragged"/>

            <ImageView fx:id="start_image"
                       fitWidth="600" fitHeight="400"
                       preserveRatio="true"
                       visible="true"/>
        </StackPane>
    </center>


    <top>

        <MenuBar prefHeight="26.0" prefWidth="128.0">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" text="New" onAction="#clicked_new_at_menu" />
                        <MenuItem mnemonicParsing="false" text="Save" onAction="#clicked_save_at_menu"/>
                        <MenuItem mnemonicParsing="false" text="Load" onAction="#clicked_load_at_menu"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Options">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Properties" onAction="#clicked_properties_on_menu" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Exit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Exit" onAction="#clicked_exit_on_menu"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="About">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About" onAction="#clicked_about_on_menu"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Help" onAction="#clicked_help_on_menu"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>



</BorderPane>
